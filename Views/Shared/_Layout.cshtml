<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MiProyectoMVC</title>
    
    <link href="https://cdnjs.cloudflare.com/ajax/libs/materialize/1.0.0/css/materialize.min.css" rel="stylesheet">
    
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
    
    <link rel="stylesheet" href="~/MiProyectoMVC.styles.css" asp-append-version="true" />

    <style>
        body {
            background: #f4f6f9;
        }
        
        nav {
            border-radius: 0 0 20px 20px;
            padding: 0 20px;
        }

        .brand-logo {
            font-weight: bold;
        }

        .layout {
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        .content {
            flex: 1;
        }
        
    </style>
</head>

<body>

<header>
    <nav class="blue darken-3">
        <div class="nav-wrapper container">
            
            <a asp-controller="Home" asp-action="Index" class="brand-logo">
                Eventos
            </a>
            
            <a href="#" data-target="mobile-menu" class="sidenav-trigger">
                <i class="material-icons">menu</i>
            </a>
            
            <ul class="right hide-on-med-and-down">
                <li><a asp-controller="Events" asp-action="Index">Admin</a></li>
                <li><a asp-controller="Events" asp-action="Gallery">Galería</a></li>
            </ul>

        </div>
    </nav>
    
    <ul class="sidenav" id="mobile-menu">
        <li><a asp-controller="Events" asp-action="Index">Admin</a></li>
        <li><a asp-controller="Events" asp-action="Gallery">Galería</a></li>
    </ul>
</header>

<div class="container content">
        @RenderBody()
</div>

<footer class="page-footer blue darken-3">
    <div class="footer-copyright">
        <div class="container">
            © 2026 - MiProyectoMVC
        </div>
    </div>
</footer>

<script src="https://cdnjs.cloudflare.com/ajax/libs/materialize/1.0.0/js/materialize.min.js"></script>

<script>
document.addEventListener('DOMContentLoaded', function () {
    
    var elems = document.querySelectorAll('.sidenav');
    M.Sidenav.init(elems);
});
</script>

@await RenderSectionAsync("Scripts", required: false)

</body>
</html>
